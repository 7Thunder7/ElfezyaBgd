{
  "compilerOptions": {
    /* Target & module */
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    /* JSX */
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "useDefineForClassFields": true,
    /* Language & libs */
    "lib": [
      "ES2021",
      "DOM",
      "DOM.Iterable",
      "ESNext"
    ],
    /* Strictness & safety */
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    /* Interop */
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    /* Paths & aliases (مهم لتطابق alias "@" في vite.config.ts) */
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    /* Types — هنا نضيف react/react-dom كي يظهر namespace JSX */
    "types": [
      "vite/client",
      "node",
      "react",
      "react-dom"
    ]
  },
  /* تضمين ملفات المشروع (يمكن تعديلها حسب هيكل مشروعك) */
  "include": [
    "src",
    "env.d.ts",
    "vite-env.d.ts",
    "src/vite-env.d.ts"
  ],
  /*
    لو انت عايز تحافظ على تقسيم الإعدادات لمقاصد مختلفة،
    اترك الـ references كما كانت (إن وُجدت).
  */
  "files": [],
  "references": [
    {
      "path": "./tsconfig.app.json"
    },
    {
      "path": "./tsconfig.node.json"
    }
  ]
}